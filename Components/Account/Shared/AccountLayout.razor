@inherits LayoutComponentBase

<div class="account-shell">
    <div class="account-card">
        <div class="account-brand">
            <img src="images/hcp-logo.png" alt="HCP" class="account-logo" />
            <div class="account-sub">HR Portal</div>
        </div>
        @Body
    </div>
    <div class="account-footer">© @DateTime.Now.Year HCP · HR Portal</div>
</div>

<style>
    .account-shell {
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #0d2c54 0%, #15489a 100%);
        padding: 1.5rem;
    }
    .account-card {
        width: 100%;
        max-width: 400px;
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 18px 50px rgba(0,0,0,.25);
        padding: 2.25rem 2rem;
    }
    .account-brand { text-align: center; margin-bottom: 1.5rem; }
    .account-logo { height: 46px; }
    .account-sub { color: #6b7280; font-size: .85rem; letter-spacing: .12em; text-transform: uppercase; margin-top: .35rem; }
    .account-footer { color: rgba(255,255,255,.75); font-size: .8rem; margin-top: 1.25rem; }
</style>
