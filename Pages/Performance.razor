@page "/performance"
@attribute [Authorize]
@inject CurrentUserService CurrentUser
@inject IPerformanceService PerfSvc

<PageTitle>Performance · HCP HR Portal</PageTitle>

<PageHeader Title="Performance"
            Subtitle="Reviews, goals &amp; feedback"
            Icon="bi-graph-up-arrow" />

@if (me is null)
{
    <p class="text-muted-sm">Loading…</p>
}
else
{
    <div class="dash-grid">
        <DashboardCard Title="Current Cycle"
                       Value="@cycle"
                       Icon="bi-calendar2-check-fill"
                       Tone="primary"
                       Trend="@cycleRange" />
        <DashboardCard Title="Overall Rating"
                       Value="@(review is null ? "—" : $"{review.Rating:0.0} / 5")"
                       Icon="bi-star-fill"
                       Tone="success"
                       Trend="@(review is null ? "Not yet rated" : BandText(review.Band))" />
        <DashboardCard Title="Goals On Track"
                       Value="@($"{onTrack} / {goals.Count}")"
                       Icon="bi-check2-circle"
                       Tone="info"
                       Trend="@(needAttention == 0 ? "All goals healthy" : $"{needAttention} goal(s) need attention")" />
    </div>

    <div class="placeholder-note" style="margin-top:1rem;">
        <span class="bi bi-info-circle-fill"></span>
        <strong>Note on data source:</strong> Ratings, goals, and feedback shown here are
        currently <strong>auto-generated sample data</strong> for system demonstration —
        the live performance-review workflow (Manager-entered ratings, employee
        self-assessments, peer feedback submissions) has not yet been implemented.
        The Q3 2026 review cycle opens on 1 July 2026.
    </div>

    <div class="two-col" style="margin-top:1.25rem;">
        <div class="card-surface">
            <h2 class="section-title">My Goals — @cycle</h2>
            @if (goals.Count == 0)
            {
                <p class="text-muted-sm">No goals set for this cycle yet.</p>
            }
            else
            {
                @foreach (var g in goals)
                {
                    <div style="margin-bottom:1.1rem;">
                        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.25rem;">
                            <span style="font-weight:600;">@g.Title</span>
                            <StatusBadge Variant="@GoalVariant(g.Status)" Text="@GoalText(g.Status)" Status="@GoalText(g.Status)" />
                        </div>
                        <div class="progress-track">
                            <div class="progress-fill" style="width:@(g.ProgressPercent)%;"></div>
                        </div>
                        <div class="cell-sub" style="margin-top:0.2rem;">@g.ProgressPercent% complete</div>
                    </div>
                }
            }
        </div>

        <div class="card-surface">
            <h2 class="section-title">Recent Feedback</h2>
            @if (feedback.Count == 0)
            {
                <p class="text-muted-sm">No feedback yet.</p>
            }
            else
            {
                @foreach (var f in feedback)
                {
                    <div class="event-row" style="margin-bottom:0.9rem;border-bottom:1px solid var(--color-border);padding-bottom:0.9rem;">
                        <div style="flex-shrink:0;">
                            <div class="avatar" style="width:2.2rem;height:2.2rem;font-size:0.8rem;">@Initials(f.Author)</div>
                        </div>
                        <div>
                            <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.2rem;">
                                <span style="font-weight:600;font-size:0.9rem;">@f.Author</span>
                                <StatusBadge Variant="secondary" Text="@f.Relation" Status="@f.Relation" />
                                <span class="text-muted-sm">@f.Date.ToString("dd MMM yyyy")</span>
                            </div>
                            <p style="margin:0;font-size:0.9rem;color:var(--color-text);">@f.Comment</p>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}

@code {
    private Employee? me;
    private PerformanceReview? review;
    private List<PerformanceGoal> goals = new();
    private List<PerformanceFeedback> feedback = new();

    private string cycle = "";
    private string cycleRange = "";
    private int onTrack;
    private int needAttention;

    protected override async Task OnInitializedAsync()
    {
        me = await CurrentUser.GetEmployeeAsync();
        if (me is null) return;

        review = PerfSvc.GetReviewForEmployee(me.Id);
        goals = PerfSvc.GetGoalsForEmployee(me.Id).ToList();
        feedback = PerfSvc.GetFeedbackForEmployee(me.Id).ToList();

        onTrack = goals.Count(g => g.Status is GoalStatus.OnTrack or GoalStatus.Completed);
        needAttention = goals.Count(g => g.Status is GoalStatus.AtRisk or GoalStatus.Behind);

        var today = DateOnly.FromDateTime(DateTime.Today);
        var q = (today.Month - 1) / 3 + 1;
        cycle = review?.Cycle ?? $"Q{q} {today.Year}";
        var startMonth = (q - 1) * 3 + 1;
        cycleRange = $"{new DateOnly(today.Year, startMonth, 1):MMM} – {new DateOnly(today.Year, startMonth + 2, 1):MMM yyyy}";
    }

    private static string Initials(string name)
    {
        var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length == 0) return "?";
        return parts.Length == 1
            ? parts[0][..1].ToUpper()
            : (parts[0][..1] + parts[^1][..1]).ToUpper();
    }

    private static string GoalText(GoalStatus s) => s switch
    {
        GoalStatus.OnTrack => "On Track",
        GoalStatus.AtRisk => "At Risk",
        GoalStatus.Behind => "Behind",
        GoalStatus.Completed => "Completed",
        _ => s.ToString()
    };

    private static string GoalVariant(GoalStatus s) => s switch
    {
        GoalStatus.OnTrack => "success",
        GoalStatus.Completed => "success",
        GoalStatus.AtRisk => "warning",
        GoalStatus.Behind => "danger",
        _ => "secondary"
    };

    private static string BandText(PerformanceBand b) => b switch
    {
        PerformanceBand.AboveExpectations => "Above expectations",
        PerformanceBand.BelowExpectations => "Below expectations",
        _ => "Meets expectations"
    };
}
