@page "/announcements"
@attribute [Authorize(Roles = Roles.HR)]
@inject IAnnouncementService AnnouncementSvc
@inject CurrentUserService CurrentUser

<PageTitle>Announcements · HCP HR Portal</PageTitle>

<PageHeader Title="Announcements"
            Subtitle="Publish and manage company-wide news"
            Icon="bi-megaphone-fill">
    <Actions>
        <button class="btn btn-primary btn-sm" @onclick="StartNew">
            <span class="bi bi-plus-lg me-1"></span>New announcement
        </button>
    </Actions>
</PageHeader>

@if (showForm)
{
    <div class="form-card mb-grid">
        <h2 class="section-title">@(_edit.Id == 0 ? "New announcement" : $"Edit — {_edit.Title}")</h2>
        <div class="form-row">
            <label>Title</label>
            <input class="form-control" @bind="_edit.Title" placeholder="e.g. Updated Travel Policy" />
        </div>
        <div class="two-col" style="align-items:start;">
            <div>
                <div class="form-row">
                    <label>Category</label>
                    <select class="form-select" @bind="_edit.Category">
                        @foreach (var c in Categories) { <option>@c</option> }
                    </select>
                </div>
                <div class="form-row">
                    <label>Date</label>
                    <input type="date" class="form-control" @bind="_edit.Date" />
                </div>
            </div>
            <div>
                <div class="form-row">
                    <label>Author</label>
                    <input class="form-control" @bind="_edit.Author" placeholder="Name, Title" />
                </div>
            </div>
        </div>
        <div class="form-row">
            <label>Body</label>
            <textarea class="form-control" rows="6" @bind="_edit.Body" placeholder="Full announcement text…"></textarea>
        </div>
        <div style="margin-top:0.75rem;">
            <button class="btn btn-primary me-1" @onclick="Save">Publish</button>
            <button class="btn btn-outline-secondary" @onclick="() => showForm = false">Cancel</button>
            @if (!string.IsNullOrEmpty(_message))
            {
                <span class="text-muted-sm" style="margin-left:0.6rem;color:@(_messageError ? "#b91c1c" : "#16a34a");">
                    <span class="bi @(_messageError ? "bi-exclamation-circle-fill" : "bi-check-circle-fill")"></span> @_message
                </span>
            }
        </div>
    </div>
}

<div style="margin-top:1rem;">
    @if (all.Count == 0)
    {
        <div class="card-surface">
            <p class="text-muted-sm">No announcements yet. Click <strong>+ New announcement</strong> to publish the first one.</p>
        </div>
    }
    else
    {
        @foreach (var a in all)
        {
            <div class="card-surface mb-grid">
                <div style="display:flex;align-items:center;gap:0.6rem;margin-bottom:0.5rem;">
                    <StatusBadge Variant="@CategoryVariant(a.Category)" Text="@a.Category" Status="@a.Category" />
                    <span class="text-muted-sm">@a.Date.ToString("dd MMM yyyy")</span>
                    <div style="margin-left:auto;display:flex;gap:0.35rem;">
                        <button class="btn btn-outline-secondary btn-sm" @onclick="() => StartEdit(a)">
                            <span class="bi bi-pencil"></span> Edit
                        </button>
                        <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(a)">
                            <span class="bi bi-trash"></span> Delete
                        </button>
                    </div>
                </div>
                <h3 style="margin:0 0 0.5rem;font-size:1.1rem;font-weight:700;">@a.Title</h3>
                <p style="margin:0 0 0.75rem;line-height:1.6;white-space:pre-wrap;">@a.Body</p>
                <div class="text-muted-sm">
                    <span class="bi bi-person-fill" style="margin-right:0.3rem;"></span>@a.Author
                </div>
            </div>
        }
    }
</div>

@code {
    private List<Announcement> all = new();
    private bool showForm;
    private Announcement _edit = NewBlank();
    private string? _message;
    private bool _messageError;

    private static readonly string[] Categories =
    {
        "Event", "Policy Update", "Benefits", "IT Notice", "Award", "General"
    };

    protected override void OnInitialized() => Reload();

    private void Reload() => all = AnnouncementSvc.GetAll().ToList();

    private void StartNew()
    {
        _edit = NewBlank();
        _message = null;
        showForm = true;
    }

    private async Task StartEdit(Announcement a)
    {
        _edit = new Announcement
        {
            Id = a.Id, Title = a.Title, Body = a.Body, Author = a.Author,
            Date = a.Date, Category = a.Category
        };
        _message = null;
        showForm = true;
        await Task.CompletedTask;
    }

    private void Save()
    {
        if (string.IsNullOrWhiteSpace(_edit.Title) || string.IsNullOrWhiteSpace(_edit.Body))
        {
            _message = "Title and body are required."; _messageError = true; return;
        }
        if (string.IsNullOrWhiteSpace(_edit.Category)) _edit.Category = "General";

        if (_edit.Id == 0) AnnouncementSvc.Add(_edit);
        else AnnouncementSvc.Update(_edit);

        Reload();
        _message = "Saved.";
        _messageError = false;
        showForm = false;
    }

    private void Delete(Announcement a)
    {
        AnnouncementSvc.Delete(a.Id);
        Reload();
    }

    private static Announcement NewBlank() => new()
    {
        Date = DateOnly.FromDateTime(DateTime.Today),
        Category = "General",
    };

    private static string CategoryVariant(string category) => category switch
    {
        "Event" => "info",
        "Policy Update" => "warning",
        "Benefits" => "primary",
        "IT Notice" => "secondary",
        "Award" => "success",
        _ => "secondary"
    };
}
