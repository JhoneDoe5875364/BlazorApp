@page "/company-directory"
@attribute [Authorize]
@inject IEmployeeService Employees

<PageTitle>Company Directory · HCP HR Portal</PageTitle>

<PageHeader Title="Company Directory" Subtitle="Find people across the organisation" Icon="bi-people-fill" />

<div class="filters-bar">
    <input class="filter-input" placeholder="Search employees…" value="@search" @oninput="OnSearch" />
    <select class="filter-select" @onchange="OnDept">
        <option value="">All departments</option>
        @foreach (var d in Employees.Departments())
        {
            <option value="@d" selected="@(d == dept)">@d</option>
        }
    </select>
</div>

<p class="text-muted-sm mb-grid">@Filtered.Count people</p>

<div class="card-grid">
    @foreach (var e in Filtered)
    {
        <div class="card-surface" style="display:flex;flex-direction:column;gap:0.6rem;">
            <div style="display:flex;align-items:center;gap:0.75rem;">
                <Avatar Name="@e.FullName" Size="lg" PhotoUrl="@e.PhotoUrl" />
                <div>
                    <div style="font-weight:700;">@e.FullName</div>
                    <div class="cell-sub">@e.JobTitle</div>
                    <div class="cell-sub">@e.Department</div>
                    <div style="margin-top:0.25rem;"><StatusBadge Status="@Roles.For(e)" Variant="@RoleVariant(Roles.For(e))" Text="@Roles.For(e)" /></div>
                </div>
            </div>
            <div class="text-muted-sm"><span class="bi bi-envelope" style="margin-right:0.4rem;"></span><a href="mailto:@e.Email">@e.Email</a></div>
            <div class="text-muted-sm">
                <span class="bi bi-telephone" style="margin-right:0.4rem;"></span>
                @if (!string.IsNullOrWhiteSpace(e.Phone))
                {
                    <a href="tel:@TelHref(e.Phone)" title="Call @e.Phone">@e.Phone</a>
                }
            </div>
            <div class="text-muted-sm"><span class="bi bi-geo-alt" style="margin-right:0.4rem;"></span>@e.Location</div>
            <div class="text-muted-sm">
                <span class="bi bi-person-badge" style="margin-right:0.4rem;"></span>Reports to:
                @{
                    var managerFull = ResolveManager(e.ManagerName);
                }
                @if (managerFull is not null)
                {
                    <a href="company-directory?search=@Uri.EscapeDataString(managerFull.FullName)"
                       title="@($"{managerFull.FullName} · {managerFull.JobTitle}")">@managerFull.FullName</a>
                }
                else if (!string.IsNullOrWhiteSpace(e.ManagerName))
                {
                    <span>@e.ManagerName</span>
                }
                else
                {
                    <span class="text-muted-sm">—</span>
                }
            </div>
        </div>
    }
    @if (Filtered.Count == 0)
    {
        <p class="text-muted-sm">No employees match your search.</p>
    }
</div>

@code {
    private List<Employee> all = new();
    private string search = "";
    private string dept = "";

    /// <summary>Deep-link target — e.g. /company-directory?search=Audrey%20DeHaven from a
    /// "Reports to" link in another card. We adopt the value as the initial filter.</summary>
    [SupplyParameterFromQuery(Name = "search")] public string? InitialSearch { get; set; }

    protected override void OnInitialized()
    {
        all = Employees.GetAll().ToList();
        if (!string.IsNullOrWhiteSpace(InitialSearch)) search = InitialSearch.Trim();
    }

    /// <summary>
    /// XLSX has manager names in mixed forms ("Audrey", "Robert Scott", "Peter").
    /// Resolve to a real Employee row by:
    ///   1. exact full-name match, or
    ///   2. first-name match (case-insensitive),
    ///   3. last-name match,
    ///   4. partial contains.
    /// Returns null if no unique match can be inferred.
    /// </summary>
    private Employee? ResolveManager(string? rawName)
    {
        if (string.IsNullOrWhiteSpace(rawName)) return null;
        var raw = rawName.Trim();

        var exact = all.FirstOrDefault(x =>
            string.Equals(x.FullName.Trim(), raw, StringComparison.OrdinalIgnoreCase));
        if (exact is not null) return exact;

        var byFirst = all.Where(x => x.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                                      .FirstOrDefault()?.Equals(raw, StringComparison.OrdinalIgnoreCase) == true)
                         .ToList();
        if (byFirst.Count == 1) return byFirst[0];

        var byLast = all.Where(x => x.FullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
                                     .LastOrDefault()?.Equals(raw, StringComparison.OrdinalIgnoreCase) == true)
                        .ToList();
        if (byLast.Count == 1) return byLast[0];

        var contains = all.Where(x => x.FullName.Contains(raw, StringComparison.OrdinalIgnoreCase)).ToList();
        return contains.Count == 1 ? contains[0] : null;
    }

    private List<Employee> Filtered
    {
        get
        {
            IEnumerable<Employee> q = all;
            if (!string.IsNullOrEmpty(dept)) q = q.Where(e => e.Department == dept);
            if (!string.IsNullOrWhiteSpace(search))
            {
                var s = search.Trim();
                q = q.Where(e => e.FullName.Contains(s, StringComparison.OrdinalIgnoreCase)
                              || e.JobTitle.Contains(s, StringComparison.OrdinalIgnoreCase)
                              || e.Department.Contains(s, StringComparison.OrdinalIgnoreCase));
            }
            return q.OrderBy(e => e.FullName).ToList();
        }
    }

    private void OnSearch(ChangeEventArgs e) => search = e.Value?.ToString() ?? "";
    private void OnDept(ChangeEventArgs e) => dept = e.Value?.ToString() ?? "";

    private static string RoleVariant(string role) => role switch
    {
        "HR" => "purple",
        "Manager" => "info",
        "Finance" => "warning",
        _ => "secondary"
    };

    /// <summary>
    /// Normalise a phone number for the tel: URI scheme — keeps only digits and a single
    /// leading '+' so the OS dialler accepts it regardless of how the source had it
    /// formatted (spaces, dashes, parentheses, etc.).
    /// </summary>
    private static string TelHref(string phone)
    {
        if (string.IsNullOrWhiteSpace(phone)) return "";
        var sb = new System.Text.StringBuilder(phone.Length);
        foreach (var ch in phone)
        {
            if (ch == '+' && sb.Length == 0) sb.Append('+');
            else if (char.IsDigit(ch)) sb.Append(ch);
        }
        return sb.ToString();
    }
}
