@page "/salary-certificates"
@attribute [Authorize]
@inject CurrentUserService CurrentUser
@inject ISalaryCertificateService CertSvc

<PageTitle>Salary Certificates · HCP HR Portal</PageTitle>

<PageHeader Title="Salary Certificates"
            Subtitle="Request a formal salary certificate (for banks, visas, embassies)"
            Icon="bi-file-earmark-text-fill" />

@if (me is null)
{
    <p class="text-muted-sm">Loading…</p>
}
else
{
    <div class="card-surface">
        <h2 class="section-title">Request a Salary Certificate</h2>
        <p>
            A formal salary certificate confirms your current position, department, and remuneration
            details. It is commonly required for visa applications, bank loans, and rental agreements.
        </p>
        <p class="text-muted-sm">
            Certificate will be addressed on behalf of: <strong>@me.FullName</strong> &middot; @me.JobTitle, @me.Department
        </p>

        <div style="margin-top:1rem;">
            <div class="form-row">
                <label>Purpose</label>
                <select class="form-select" @bind="purpose">
                    <option>Bank loan</option>
                    <option>Visa application</option>
                    <option>Rental agreement</option>
                    <option>Embassy / consulate</option>
                    <option>Other</option>
                </select>
            </div>
            <div class="form-row">
                <label>Addressed to (bank, landlord, embassy…)</label>
                <input class="form-control" @bind="addressee" placeholder="e.g. Emirates NBD" />
            </div>
        </div>

        <div style="margin-top: 1rem;">
            <button class="btn btn-primary" @onclick="Submit">
                <span class="bi bi-file-earmark-text me-1"></span>Request certificate
            </button>
            @if (justRequested)
            {
                <span class="text-success ms-2"><span class="bi bi-check-circle-fill me-1"></span>Request submitted.</span>
            }
        </div>

        <div class="placeholder-note" style="margin-top: 1rem;">
            <span class="bi bi-info-circle-fill"></span>
            For your monthly payslips (different document), see the <a href="payslips"><strong>Payslips</strong></a> page.
            Requests are processed by HR within 3 business days. You will receive an email
            notification when your certificate is ready to download.
        </div>

        @if (myRequests.Count > 0)
        {
            <h2 class="section-title" style="margin-top:1.5rem;">My Requests</h2>
            <DataTable Items="myRequests" EmptyMessage="No requests yet.">
                <HeaderTemplate>
                    <th>Requested</th>
                    <th>Purpose</th>
                    <th>Addressed to</th>
                    <th>Status</th>
                </HeaderTemplate>
                <RowTemplate Context="r">
                    <td>@r.RequestedOn.ToString("dd MMM yyyy")</td>
                    <td>@r.Purpose</td>
                    <td>@r.Addressee</td>
                    <td><StatusBadge Status="@r.Status.ToString()" Variant="@StatusVariant(r.Status)" Text="@r.Status.ToString()" /></td>
                </RowTemplate>
            </DataTable>
        }
    </div>
}

@code {
    private Employee? me;
    private List<SalaryCertificateRequest> myRequests = new();

    private string purpose = "Bank loan";
    private string addressee = "";
    private bool justRequested;

    protected override async Task OnInitializedAsync()
    {
        me = await CurrentUser.GetEmployeeAsync();
        if (me is null) return;
        Reload();
    }

    private void Reload() => myRequests = me is null ? new() : CertSvc.GetForEmployee(me.Id).ToList();

    private void Submit()
    {
        if (me is null) return;

        CertSvc.Add(new SalaryCertificateRequest
        {
            EmployeeId = me.Id,
            EmployeeName = me.FullName,
            Purpose = purpose,
            Addressee = string.IsNullOrWhiteSpace(addressee) ? "—" : addressee.Trim(),
            RequestedOn = DateOnly.FromDateTime(DateTime.Today),
            Status = CertificateStatus.Pending,
        });

        justRequested = true;
        addressee = "";
        Reload();
    }

    private static string StatusVariant(CertificateStatus s) => s switch
    {
        CertificateStatus.Issued => "success",
        CertificateStatus.Rejected => "danger",
        CertificateStatus.Processing => "info",
        _ => "warning"
    };
}
