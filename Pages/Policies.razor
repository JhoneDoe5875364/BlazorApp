@page "/policies"
@attribute [Authorize]
@inject IPolicyService PolicySvc
@inject CurrentUserService CurrentUser
@inject AuthenticationStateProvider AuthState
@inject ISharePointFileService SharePoint
@inject IWebHostEnvironment Env
@inject ILogger<Policies> Logger

<PageTitle>Company Policies · HCP HR Portal</PageTitle>

<PageHeader Title="Policies &amp; Acknowledgements"
            Subtitle="Company policies and your acknowledgement status"
            Icon="bi-file-earmark-text-fill">
    <Actions>
        @if (isHR)
        {
            <button class="btn btn-primary btn-sm" @onclick="StartNew">
                <span class="bi bi-plus-lg me-1"></span>New policy
            </button>
        }
    </Actions>
</PageHeader>

@if (email is null)
{
    <p class="text-muted-sm">Loading…</p>
}
else
{
    @if (isHR && showForm)
    {
        <div class="form-card mb-grid">
            <h2 class="section-title">@(_edit.Id == 0 ? "Add new policy" : $"Edit — {_edit.Name}")</h2>
            <div class="two-col" style="align-items:start;">
                <div>
                    <div class="form-row"><label>Name</label><input class="form-control" @bind="_edit.Name" placeholder="e.g. Travel & Expense Policy" /></div>
                    <div class="form-row">
                        <label>Category</label>
                        <select class="form-select" @bind="_edit.Category">
                            <option>HR</option><option>Compliance</option><option>IT</option>
                            <option>Finance</option><option>HSE</option><option>Operations</option>
                        </select>
                    </div>
                    <div class="form-row"><label>Version</label><input class="form-control" @bind="_edit.Version" placeholder="v1.0" /></div>
                </div>
                <div>
                    <div class="form-row"><label>Effective date / last updated</label><input class="form-control" @bind="_edit.Updated" placeholder="e.g. 01 Jul 2026" /></div>
                    <div class="form-row">
                        <label class="set-check"><input type="checkbox" @bind="_edit.Mandatory" /> Mandatory (all employees must acknowledge)</label>
                    </div>
                    <div class="form-row">
                        <label>Policy PDF</label>
                        <InputFile class="form-control" OnChange="OnPdfSelected" accept=".pdf" />
                        @if (_pickedPdf is not null)
                        {
                            <div class="text-muted-sm" style="margin-top:0.3rem;">
                                <span class="bi bi-paperclip"></span> @_pickedPdf.Name
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_edit.DocumentUrl))
                        {
                            <div class="text-muted-sm" style="margin-top:0.3rem;">
                                Current: <a href="@_edit.DocumentUrl" target="_blank" rel="noopener">view existing PDF</a>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <button class="btn btn-primary me-1" @onclick="SavePolicy" disabled="@_busy">
                @(_busy ? "Saving…" : "Save policy")
            </button>
            <button class="btn btn-outline-secondary" @onclick="() => showForm = false">Cancel</button>
            @if (!string.IsNullOrEmpty(_message))
            {
                <span class="text-muted-sm" style="margin-left:0.6rem;color:@(_messageError ? "#b91c1c" : "#16a34a");">
                    <span class="bi @(_messageError ? "bi-exclamation-circle-fill" : "bi-check-circle-fill")"></span> @_message
                </span>
            }
        </div>
    }

    <div class="dash-grid">
        <DashboardCard Title="Total Policies" Value="@PolicySvc.All.Count.ToString()" Icon="bi-file-earmark-text-fill" Tone="primary" Trend="Published" />
        <DashboardCard Title="Acknowledged" Value="@ackCount.ToString()" Icon="bi-check-circle-fill" Tone="success" Trend="Signed by you" />
        <DashboardCard Title="Pending" Value="@pendingCount.ToString()" Icon="bi-hourglass-split" Tone="warning" Trend="Awaiting acknowledgement" />
        <DashboardCard Title="Overdue" Value="@overdueCount.ToString()" Icon="bi-exclamation-triangle-fill" Tone="danger" Trend="Mandatory &amp; unsigned" />
    </div>

    <div class="card-surface">
        <div class="cal-tabs">
            @foreach (var t in tabs)
            {
                <button class="cal-tab @(t == tab ? "active" : "")" @onclick="() => tab = t">@t</button>
            }
        </div>

        @if (tab == "Policies")
        {
            <DataTable Items="PolicySvc.All" EmptyMessage="No policies found.">
                <HeaderTemplate>
                    <th>Policy Name</th>
                    <th>Category</th>
                    <th>Version</th>
                    <th>Last Updated</th>
                    <th>Document</th>
                    @if (isHR) { <th>Manage</th> }
                </HeaderTemplate>
                <RowTemplate Context="p">
                    <td style="font-weight:600">@p.Name @if (p.Mandatory) { <span class="status-badge sb-warning" style="margin-left:0.3rem;font-size:0.68rem;">Mandatory</span> }</td>
                    <td><StatusBadge Variant="info" Text="@p.Category" Status="@p.Category" /></td>
                    <td>@p.Version</td>
                    <td>@p.Updated</td>
                    <td>
                        @if (!string.IsNullOrEmpty(p.DocumentUrl))
                        {
                            <a class="section-link" href="@p.DocumentUrl" target="_blank" rel="noopener">View →</a>
                        }
                        else
                        {
                            <span class="text-muted-sm" title="No PDF uploaded yet">Pending upload</span>
                        }
                    </td>
                    @if (isHR)
                    {
                        <td>
                            <button class="btn btn-outline-secondary btn-sm me-1" @onclick="() => StartEdit(p)" title="Edit">
                                <span class="bi bi-pencil"></span>
                            </button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => Delete(p)" title="Delete">
                                <span class="bi bi-trash"></span>
                            </button>
                        </td>
                    }
                </RowTemplate>
            </DataTable>
        }
        else
        {
            <DataTable Items="PolicySvc.All" EmptyMessage="No acknowledgements.">
                <HeaderTemplate>
                    <th>Policy Name</th><th>Version</th><th>Acknowledged Date</th><th>Status</th><th>Action</th>
                </HeaderTemplate>
                <RowTemplate Context="p">
                    <td style="font-weight:600">@p.Name</td>
                    <td>@p.Version</td>
                    <td>@(PolicySvc.AcknowledgedOn(email!, p.Id)?.ToString("dd MMM yyyy") ?? "—")</td>
                    <td>
                        @if (PolicySvc.IsAcknowledged(email!, p.Id))
                        {
                            <StatusBadge Variant="success" Text="Acknowledged" Status="Acknowledged" />
                        }
                        else if (p.Mandatory)
                        {
                            <StatusBadge Variant="danger" Text="Overdue" Status="Overdue" />
                        }
                        else
                        {
                            <StatusBadge Variant="warning" Text="Pending" Status="Pending" />
                        }
                    </td>
                    <td>
                        @if (!PolicySvc.IsAcknowledged(email!, p.Id))
                        {
                            <button class="btn btn-primary btn-sm" @onclick="() => Acknowledge(p.Id)">Acknowledge</button>
                        }
                        else { <span class="text-muted-sm">—</span> }
                    </td>
                </RowTemplate>
            </DataTable>
        }
    </div>
}

@code {
    private const long MaxPdfBytes = 10 * 1024 * 1024;
    private const string PoliciesLibrary = "Public HR Documents";
    private const string PoliciesFolder = "Policies";

    private Employee? me;
    private string? email;
    private string tab = "Policies";
    private readonly string[] tabs = { "Policies", "Acknowledgements" };
    private bool isHR;

    private bool showForm;
    private bool _busy;
    private string? _message;
    private bool _messageError;
    private CompanyPolicy _edit = new();
    private IBrowserFile? _pickedPdf;

    protected override async Task OnInitializedAsync()
    {
        me = await CurrentUser.GetEmployeeAsync();
        email = me?.Email;

        var auth = await AuthState.GetAuthenticationStateAsync();
        isHR = auth.User.IsInRole(Roles.HR);
    }

    private int ackCount => email is null ? 0 : PolicySvc.All.Count(p => PolicySvc.IsAcknowledged(email, p.Id));
    private int pendingCount => email is null ? 0 : PolicySvc.All.Count(p => !PolicySvc.IsAcknowledged(email, p.Id));
    private int overdueCount => email is null ? 0 : PolicySvc.All.Count(p => p.Mandatory && !PolicySvc.IsAcknowledged(email, p.Id));

    private void Acknowledge(int policyId)
    {
        if (email is not null) PolicySvc.Acknowledge(email, policyId);
    }

    private void StartNew()
    {
        _edit = new CompanyPolicy { Category = "HR", Version = "v1.0", Mandatory = true };
        _pickedPdf = null;
        _message = null;
        showForm = true;
    }

    private void StartEdit(CompanyPolicy p)
    {
        _edit = new CompanyPolicy
        {
            Id = p.Id, Name = p.Name, Category = p.Category, Version = p.Version,
            Updated = p.Updated, Mandatory = p.Mandatory, DocumentUrl = p.DocumentUrl,
        };
        _pickedPdf = null;
        _message = null;
        showForm = true;
    }

    private void OnPdfSelected(InputFileChangeEventArgs e)
    {
        if (e.File.Size <= MaxPdfBytes) _pickedPdf = e.File;
    }

    private async Task SavePolicy()
    {
        _message = null; _messageError = false;
        if (string.IsNullOrWhiteSpace(_edit.Name))
        { _message = "Policy name is required."; _messageError = true; return; }

        _busy = true;
        try
        {
            // Upload PDF first if one was selected. SharePoint preferred → disk fallback.
            if (_pickedPdf is not null)
            {
                var safeName = Path.GetFileName(_pickedPdf.Name);
                var uploaded = false;
                if (SharePoint.IsEnabled)
                {
                    try
                    {
                        using var buf = new MemoryStream();
                        await _pickedPdf.OpenReadStream(MaxPdfBytes).CopyToAsync(buf);
                        buf.Position = 0;
                        var result = await SharePoint.UploadToLibraryAsync(
                            PoliciesLibrary, PoliciesFolder, safeName, buf);
                        _edit.DocumentUrl = result.WebUrl;
                        uploaded = true;
                        Logger.LogInformation("[SharePoint] Policy PDF uploaded → {Url}", result.WebUrl);
                    }
                    catch (Exception ex)
                    {
                        Logger.LogWarning(ex, "[SharePoint] Policy upload to library failed — falling back to disk.");
                    }
                }
                if (!uploaded)
                {
                    var dir = Path.Combine(Env.WebRootPath, "uploads", "policies");
                    Directory.CreateDirectory(dir);
                    var stored = $"{Guid.NewGuid():N}_{safeName}";
                    var path = Path.Combine(dir, stored);
                    await using (var fs = File.Create(path))
                    await using (var src = _pickedPdf.OpenReadStream(MaxPdfBytes))
                        await src.CopyToAsync(fs);
                    _edit.DocumentUrl = $"uploads/policies/{stored}";
                }
            }

            if (_edit.Id == 0) PolicySvc.Add(_edit); else PolicySvc.Update(_edit);
            _message = "Saved.";
            showForm = false;
        }
        catch (Exception ex)
        {
            _message = ex.Message; _messageError = true;
        }
        finally { _busy = false; }
    }

    private void Delete(CompanyPolicy p)
    {
        PolicySvc.Delete(p.Id);
    }
}
