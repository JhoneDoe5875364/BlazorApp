@page "/benefits"
@attribute [Authorize]

<PageTitle>Benefits · HCP HR Portal</PageTitle>

<PageHeader Title="Benefits &amp; Perks"
            Subtitle="Your HCP benefits &amp; perks"
            Icon="bi-heart-fill" />

<div class="placeholder-note" style="margin-top:1rem;">
    <span class="bi bi-info-circle-fill"></span>
    Enrollment changes are only permitted during the annual open-enrollment window (1–30 November each year). Contact HR to request an exception outside this period.
</div>

<div class="card-grid" style="margin-top:1.25rem;">
    @foreach (var b in _benefits)
    {
        <div class="card-surface" style="display:flex;flex-direction:column;gap:0.6rem;">
            <div style="display:flex;align-items:center;gap:0.75rem;">
                <span class="bi @b.Icon" style="font-size:1.6rem;color:var(--color-primary);flex-shrink:0;"></span>
                <div>
                    <div style="font-weight:700;font-size:1rem;">@b.Title</div>
                    <StatusBadge Variant="@b.BadgeVariant" Text="@b.BadgeText" Status="@b.BadgeText" />
                </div>
            </div>
            <p class="text-muted-sm" style="margin:0;">@b.Description</p>
        </div>
    }
</div>

@code {
    private record BenefitItem(string Title, string Icon, string Description, string BadgeVariant, string BadgeText);

    private readonly BenefitItem[] _benefits =
    {
        new("Health Insurance",    "bi-heart-pulse-fill",
            "Comprehensive medical cover for you and your dependants, including specialist referrals and emergency worldwide assistance.",
            "success", "Enrolled"),

        new("Dental & Vision",     "bi-eye-fill",
            "Annual dental check-ups, orthodontic contributions, and optical allowance up to $400 per year.",
            "success", "Enrolled"),

        new("Pension / 401(k)",    "bi-piggy-bank-fill",
            "Company matches contributions up to 6% of your base salary. Vesting begins after 12 months of service.",
            "success", "Enrolled"),

        new("Life Insurance",      "bi-shield-fill-check",
            "Group life insurance providing 4× your annual base salary, with optional top-up available through payroll.",
            "success", "Enrolled"),

        new("Wellness Allowance",  "bi-activity",
            "Up to $600 per year reimbursed for eligible wellness expenses: gym, meditation apps, nutrition coaching, and more.",
            "info", "Available"),

        new("Learning Budget",     "bi-book-fill",
            "$1,500 annual budget for external courses, conferences, books, and professional certifications.",
            "success", "Enrolled"),

        new("Remote Work Stipend", "bi-house-heart-fill",
            "One-time $750 home-office setup allowance plus $50/month towards broadband for eligible remote employees.",
            "success", "Enrolled"),

        new("Gym Membership",      "bi-bicycle",
            "Subsidised corporate gym memberships at partner facilities. HCP covers 70% of the monthly fee at approved locations.",
            "info", "Available"),
    };
}
