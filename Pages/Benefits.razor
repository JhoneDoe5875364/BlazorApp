@page "/benefits"
@attribute [Authorize]

<PageTitle>Benefits · HCP HR Portal</PageTitle>

<PageHeader Title="Benefits &amp; Perks"
            Subtitle="Your HCP benefits &amp; perks"
            Icon="bi-heart-fill" />

<div class="placeholder-note" style="margin-top:1rem;">
    <span class="bi bi-info-circle-fill"></span>
    Enrollment changes are only permitted during the annual open-enrollment window (1–30 November each year). Contact HR to request an exception outside this period.
</div>

<div class="card-grid" style="margin-top:1.25rem;">
    @foreach (var b in _benefits)
    {
        <div class="card-surface" style="display:flex;flex-direction:column;gap:0.6rem;">
            <div style="display:flex;align-items:center;gap:0.75rem;">
                <span class="bi @b.Icon" style="font-size:1.6rem;color:var(--color-primary);flex-shrink:0;"></span>
                <div>
                    <div style="font-weight:700;font-size:1rem;">@b.Title</div>
                    <StatusBadge Variant="@b.BadgeVariant" Text="@b.BadgeText" Status="@b.BadgeText" />
                </div>
            </div>
            <p class="text-muted-sm" style="margin:0;">@b.Description</p>
        </div>
    }
</div>

@code {
    private record BenefitItem(string Title, string Icon, string Description, string BadgeVariant, string BadgeText);

    private readonly BenefitItem[] _benefits =
    {
        new("Health Insurance",    "bi-heart-pulse-fill",
            "Comprehensive medical cover for you and your dependants, including specialist referrals and emergency worldwide assistance.",
            "success", "Enrolled"),
    };
}
